#!/usr/bin/env bash
set -euo pipefail

VERSION="dev"

usage() {
    cat <<'USAGE'
Usage: new-app-config <project-name> [--path <dir>] [--domain <domain>] [--www] [--preview-domain <domain>] [--repo <owner/name>] [--framework <laravel>] [--runtime <php>]

Options:
  --path <dir>             Project directory (default: ~/git/<project-name>)
  --domain <domain>        Primary production domain, e.g. plotling.app
  --www                    Add www.<domain> when --domain is set
  --preview-domain <name>  Explicit preview domain
  --repo <owner/name>      GitHub repository slug (default: batjaa/<project-name>)
  --framework <name>       Framework name (default: laravel)
  --runtime <name>         Runtime name (default: php)
  --version                Print version
  -h, --help               Show this help
USAGE
}

if [[ $# -eq 0 ]]; then
    usage
    exit 1
fi

PROJECT=""
PROJECT_PATH=""
PRIMARY_DOMAIN=""
ADD_WWW=false
PREVIEW_DOMAIN=""
REPO_SLUG=""
FRAMEWORK="laravel"
RUNTIME="php"

while [[ $# -gt 0 ]]; do
    case "$1" in
        --path) PROJECT_PATH="$2"; shift 2 ;;
        --domain) PRIMARY_DOMAIN="$2"; shift 2 ;;
        --www) ADD_WWW=true; shift ;;
        --preview-domain) PREVIEW_DOMAIN="$2"; shift 2 ;;
        --repo) REPO_SLUG="$2"; shift 2 ;;
        --framework) FRAMEWORK="$2"; shift 2 ;;
        --runtime) RUNTIME="$2"; shift 2 ;;
        --version) echo "new-app-config $VERSION"; exit 0 ;;
        -h|--help) usage; exit 0 ;;
        -*) echo "Unknown option: $1" >&2; exit 1 ;;
        *) PROJECT="$1"; shift ;;
    esac
done

if [[ -z "$PROJECT" ]]; then
    echo "Error: project name required" >&2
    exit 1
fi

if [[ -z "$PROJECT_PATH" ]]; then
    PROJECT_PATH="${HOME}/git/${PROJECT}"
fi

if [[ ! -d "$PROJECT_PATH" ]]; then
    echo "Error: project directory '$PROJECT_PATH' does not exist" >&2
    exit 1
fi

if [[ -z "$REPO_SLUG" ]]; then
    REPO_SLUG="batjaa/$PROJECT"
fi

if [[ -z "$PREVIEW_DOMAIN" ]]; then
    PREVIEW_DOMAIN="${PROJECT}.preview.batjaa.site"
fi

cd "$PROJECT_PATH"
mkdir -p .batjaa

DOMAINS_BLOCK=""
if [[ -n "$PRIMARY_DOMAIN" ]]; then
    DOMAINS_BLOCK+="  - ${PRIMARY_DOMAIN}"$'\n'
    if $ADD_WWW; then
        DOMAINS_BLOCK+="  - www.${PRIMARY_DOMAIN}"$'\n'
    fi
fi

cat > .batjaa/app.yml <<EOF
name: ${PROJECT}
repo: ${REPO_SLUG}
framework: ${FRAMEWORK}
runtime: ${RUNTIME}
$(if [[ -n "$DOMAINS_BLOCK" ]]; then
    printf 'production_domains:\n%s' "$DOMAINS_BLOCK"
else
    printf 'production_domains: []\n'
fi)
preview_domain: ${PREVIEW_DOMAIN}
database:
  driver: postgres
  name: ${PROJECT}
deploy:
  type: docker_compose
  compose_file: compose.yml
  service: app
  port: 80
coolify:
  environment: production
EOF

echo "==> Wrote ${PROJECT_PATH}/.batjaa/app.yml"
