#!/usr/bin/env bash
set -euo pipefail

VERSION="dev"

usage() {
    cat <<'USAGE'
Usage: new-app <project-name> [new-laravel options] [--path <dir>] [--domain <domain>] [--www] [--preview-domain <domain>] [--public|--private] [--description <text>] [--owner <owner>] [--skip-wormmon] [--dry-run] [--yes]

Wrapper flow:
  1. Scaffold a Laravel app via new-laravel
  2. Write .batjaa/app.yml via new-app-config
  3. Generate Docker/Coolify deployment files
  4. Create and push a GitHub repo via new-repo
  5. Create the preview deployment on wormmon via new-wormmon-app

Wrapper options:
  --path <dir>             Project directory (default: ~/git/<project-name>)
  --domain <domain>        Primary production domain, e.g. plotling.app
  --www                    Add www.<domain> when --domain is set
  --preview-domain <name>  Explicit preview domain
  --public                 Create a public GitHub repo
  --private                Create a private GitHub repo (default)
  --description <text>     GitHub repository description
  --owner <owner>          GitHub owner/org (default: batjaa)
  --skip-wormmon           Skip the Coolify preview deployment step
  --dry-run                Print validation and planned actions without changing anything
  --yes                    Skip confirmation prompt after validation
  --version                Print version
  -h, --help               Show this help

Any remaining options are passed through to new-laravel.
USAGE
}

if [[ $# -eq 0 ]]; then
    usage
    exit 1
fi

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

PROJECT=""
PROJECT_PATH=""
PRIMARY_DOMAIN=""
ADD_WWW=false
PREVIEW_DOMAIN=""
VISIBILITY="private"
DESCRIPTION=""
OWNER="batjaa"
SKIP_WORMMON=false
DRY_RUN=false
ASSUME_YES=false
LARAVEL_ARGS=()

while [[ $# -gt 0 ]]; do
    case "$1" in
        --path) PROJECT_PATH="$2"; shift 2 ;;
        --domain) PRIMARY_DOMAIN="$2"; shift 2 ;;
        --www) ADD_WWW=true; shift ;;
        --preview-domain) PREVIEW_DOMAIN="$2"; shift 2 ;;
        --public) VISIBILITY="public"; shift ;;
        --private) VISIBILITY="private"; shift ;;
        --description) DESCRIPTION="$2"; shift 2 ;;
        --owner) OWNER="$2"; shift 2 ;;
        --skip-wormmon) SKIP_WORMMON=true; shift ;;
        --dry-run) DRY_RUN=true; shift ;;
        --yes) ASSUME_YES=true; shift ;;
        --version) echo "new-app $VERSION"; exit 0 ;;
        -h|--help) usage; exit 0 ;;
        -*) LARAVEL_ARGS+=("$1"); if [[ "${1:-}" == "--frontend" ]]; then LARAVEL_ARGS+=("$2"); shift 2; else shift; fi ;;
        *)
            if [[ -z "$PROJECT" ]]; then
                PROJECT="$1"
                shift
                continue
            fi
            echo "Unknown positional argument: $1" >&2
            exit 1
            ;;
    esac
done

if [[ -z "$PROJECT" ]]; then
    echo "Error: project name required" >&2
    exit 1
fi

if [[ -z "$PROJECT_PATH" ]]; then
    PROJECT_PATH="${HOME}/git/${PROJECT}"
fi

if ! command -v gh >/dev/null 2>&1; then
    echo "Error: GitHub CLI 'gh' is required" >&2
    exit 1
fi

if ! gh auth status >/dev/null 2>&1; then
    echo "Error: GitHub CLI is not authenticated" >&2
    exit 1
fi

if ! $SKIP_WORMMON; then
    for var_name in COOLIFY_URL COOLIFY_TOKEN COOLIFY_SERVER_UUID COOLIFY_DESTINATION_UUID; do
        if [[ -z "${!var_name:-}" ]]; then
            echo "Error: ${var_name} is required unless --skip-wormmon is used" >&2
            exit 1
        fi
    done
fi

project_path="$PROJECT_PATH"
repo_slug="${OWNER}/${PROJECT}"
project_parent="$(dirname "$project_path")"
project_dirname="$(basename "$project_path")"

dir_exists=false
if [[ -e "$project_path" ]]; then
    dir_exists=true
fi

repo_exists=false
if command -v gh >/dev/null 2>&1 && gh repo view "$repo_slug" >/dev/null 2>&1; then
    repo_exists=true
fi

check_dns() {
    local domain="$1"
    if [[ -z "$domain" ]]; then
        echo "n/a"
        return
    fi
    local answers
    answers="$(dig +short "$domain" 2>/dev/null || true)"
    if [[ -n "$answers" ]]; then
        echo "in_use"
    else
        echo "free"
    fi
}

check_preview_dns() {
    local domain="$1"
    if [[ -z "$domain" ]]; then
        echo "n/a"
        return
    fi

    local answers
    answers="$(dig +short "$domain" 2>/dev/null || true)"

    if [[ "$domain" == *.preview.batjaa.site ]]; then
        if [[ -n "$answers" ]]; then
            echo "managed_by_wildcard"
        else
            echo "missing"
        fi
        return
    fi

    if [[ -n "$answers" ]]; then
        echo "in_use"
    else
        echo "free"
    fi
}

preview_to_check="$PREVIEW_DOMAIN"
if [[ -z "$preview_to_check" ]]; then
    preview_to_check="${PROJECT}.preview.batjaa.site"
fi

primary_domain_status="$(check_dns "$PRIMARY_DOMAIN")"
www_domain_status="n/a"
if $ADD_WWW && [[ -n "$PRIMARY_DOMAIN" ]]; then
    www_domain_status="$(check_dns "www.${PRIMARY_DOMAIN}")"
fi
preview_domain_status="$(check_preview_dns "$preview_to_check")"

warnings=()
if [[ "$primary_domain_status" == "in_use" ]]; then
    warnings+=("primary domain '${PRIMARY_DOMAIN}' already resolves in DNS")
fi

if [[ "$www_domain_status" == "in_use" ]]; then
    warnings+=("www domain 'www.${PRIMARY_DOMAIN}' already resolves in DNS")
fi

if [[ "$preview_domain_status" == "missing" ]]; then
    warnings+=("preview domain '${preview_to_check}' does not currently resolve")
fi

if [[ "$preview_domain_status" == "in_use" ]]; then
    warnings+=("preview domain '${preview_to_check}' already resolves outside the managed wildcard pattern")
fi

echo "==> Validation"
echo "  project path: ${project_path}"
echo "  local dir available: $( $dir_exists && echo no || echo yes )"
echo "  github repo: ${repo_slug}"
echo "  repo available: $( $repo_exists && echo no || echo yes )"
echo "  production domain DNS: ${primary_domain_status}"
if $ADD_WWW && [[ -n "$PRIMARY_DOMAIN" ]]; then
    echo "  www domain DNS: ${www_domain_status}"
fi
echo "  preview domain: ${preview_to_check}"
echo "  preview domain DNS: ${preview_domain_status}"
echo "  wormmon rollout: $( $SKIP_WORMMON && echo skipped || echo enabled )"
if [[ ${#warnings[@]} -gt 0 ]]; then
    echo "  warnings:"
    for warning in "${warnings[@]}"; do
        echo "    - ${warning}"
    done
fi

if $dir_exists; then
    echo "Error: local path '${project_path}' already exists" >&2
    exit 1
fi

if $repo_exists; then
    echo "Error: GitHub repo '${repo_slug}' already exists" >&2
    exit 1
fi

if $DRY_RUN; then
    echo "==> Dry run complete. No changes made."
    exit 0
fi

if ! $ASSUME_YES; then
    if [[ ${#warnings[@]} -gt 0 ]]; then
        read -r -p "Proceed after reviewing the warnings above? (y/N) " reply
    else
        read -r -p "Proceed with scaffold, manifest, and repo creation? (y/N) " reply
    fi
    if [[ ! "$reply" =~ ^[Yy]$ ]]; then
        echo "Aborted."
        exit 1
    fi
fi

mkdir -p "$project_parent"
(
    cd "$project_parent"
    "${SCRIPT_DIR}/new-laravel" "$project_dirname" "${LARAVEL_ARGS[@]}"
)

CONFIG_ARGS=("$PROJECT" --path "$project_path" --repo "${OWNER}/${PROJECT}")
if [[ -n "$PRIMARY_DOMAIN" ]]; then
    CONFIG_ARGS+=(--domain "$PRIMARY_DOMAIN")
fi
if $ADD_WWW; then
    CONFIG_ARGS+=(--www)
fi
if [[ -n "$PREVIEW_DOMAIN" ]]; then
    CONFIG_ARGS+=(--preview-domain "$PREVIEW_DOMAIN")
fi

"${SCRIPT_DIR}/new-app-config" "${CONFIG_ARGS[@]}"
"${SCRIPT_DIR}/new-laravel-deploy" "$PROJECT" --path "$project_path"

REPO_ARGS=("$PROJECT" --path "$project_path" "--${VISIBILITY}" --owner "$OWNER")
if [[ -n "$DESCRIPTION" ]]; then
    REPO_ARGS+=(--description "$DESCRIPTION")
fi
if $ASSUME_YES; then
    REPO_ARGS+=(--yes)
fi

"${SCRIPT_DIR}/new-repo" "${REPO_ARGS[@]}"

if ! $SKIP_WORMMON; then
    WORMMON_ARGS=("$PROJECT" --path "$project_path")
    if $ASSUME_YES; then
        WORMMON_ARGS+=(--yes)
    fi
    "${SCRIPT_DIR}/new-wormmon-app" "${WORMMON_ARGS[@]}"
fi

echo ""
echo "==> App scaffolded, configured, and pushed."
if $SKIP_WORMMON; then
    echo "==> Coolify rollout skipped."
else
    echo "==> Coolify preview rollout created for ${preview_to_check}"
fi
