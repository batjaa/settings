#!/usr/bin/env bash
set -euo pipefail

VERSION="dev"

usage() {
    cat <<'USAGE'
Usage: new-laravel-deploy <project-name> [--path <dir>] [--force]

Generate a basic Coolify-ready Docker Compose deployment for a Laravel app.

Options:
  --path <dir>   Project directory (default: ~/git/<project-name>)
  --force        Overwrite existing deployment files
  --version      Print version
  -h, --help     Show this help
USAGE
}

if [[ $# -eq 0 ]]; then
    usage
    exit 1
fi

PROJECT=""
PROJECT_PATH=""
FORCE=false

while [[ $# -gt 0 ]]; do
    case "$1" in
        --path) PROJECT_PATH="$2"; shift 2 ;;
        --force) FORCE=true; shift ;;
        --version) echo "new-laravel-deploy $VERSION"; exit 0 ;;
        -h|--help) usage; exit 0 ;;
        -*) echo "Unknown option: $1" >&2; exit 1 ;;
        *) PROJECT="$1"; shift ;;
    esac
done

if [[ -z "$PROJECT" ]]; then
    echo "Error: project name required" >&2
    exit 1
fi

if [[ -z "$PROJECT_PATH" ]]; then
    PROJECT_PATH="${HOME}/git/${PROJECT}"
fi

if [[ ! -d "$PROJECT_PATH" ]]; then
    echo "Error: project directory '$PROJECT_PATH' does not exist" >&2
    exit 1
fi

write_file() {
    local target="$1"
    local tmp
    tmp="$(mktemp)"
    cat > "$tmp"

    if [[ -e "$target" ]] && ! $FORCE; then
        echo "Error: '$target' already exists. Re-run with --force to overwrite." >&2
        rm -f "$tmp"
        exit 1
    fi

    mkdir -p "$(dirname "$target")"
    mv "$tmp" "$target"
}

write_file "${PROJECT_PATH}/Dockerfile" <<'EOF'
FROM php:8.4-cli-alpine

RUN apk add --no-cache \
    bash \
    curl \
    git \
    icu-dev \
    libzip-dev \
    nodejs \
    npm \
    oniguruma-dev \
    postgresql-dev \
    unzip \
    zip \
    && docker-php-ext-install \
        bcmath \
        exif \
        intl \
        mbstring \
        pcntl \
        pdo_pgsql \
        zip

COPY --from=composer:2 /usr/bin/composer /usr/bin/composer

WORKDIR /var/www/html

COPY composer.json composer.lock ./
RUN composer install --no-dev --prefer-dist --no-interaction --no-scripts

COPY package*.json ./
RUN if [ -f package-lock.json ]; then npm ci; else npm install; fi

COPY . .

RUN composer install --no-dev --prefer-dist --no-interaction --optimize-autoloader \
    && npm run build \
    && php artisan package:discover --ansi \
    && rm -rf node_modules

EXPOSE 80

ENTRYPOINT ["./.docker/app/entrypoint.sh"]
CMD ["app"]
EOF

write_file "${PROJECT_PATH}/compose.yml" <<EOF
services:
  app:
    build:
      context: .
      dockerfile: Dockerfile
    environment:
      APP_NAME: \${APP_NAME:-${PROJECT}}
      APP_ENV: \${APP_ENV:-production}
      APP_DEBUG: \${APP_DEBUG:-false}
      APP_URL: \${APP_URL:?APP_URL is required}
      APP_KEY: \${APP_KEY:?APP_KEY is required}
      LOG_CHANNEL: \${LOG_CHANNEL:-stack}
      LOG_LEVEL: \${LOG_LEVEL:-info}
      DB_CONNECTION: \${DB_CONNECTION:-pgsql}
      DB_HOST: \${DB_HOST:-db}
      DB_PORT: \${DB_PORT:-5432}
      DB_DATABASE: \${DB_DATABASE:?DB_DATABASE is required}
      DB_USERNAME: \${DB_USERNAME:?DB_USERNAME is required}
      DB_PASSWORD: \${DB_PASSWORD:?DB_PASSWORD is required}
      CACHE_STORE: \${CACHE_STORE:-database}
      QUEUE_CONNECTION: \${QUEUE_CONNECTION:-database}
      SESSION_DRIVER: \${SESSION_DRIVER:-database}
      RUN_MIGRATIONS: \${RUN_MIGRATIONS:-true}
    expose:
      - "80"
    depends_on:
      db:
        condition: service_healthy

  worker:
    build:
      context: .
      dockerfile: Dockerfile
    command: ["worker"]
    environment:
      APP_NAME: \${APP_NAME:-${PROJECT}}
      APP_ENV: \${APP_ENV:-production}
      APP_DEBUG: \${APP_DEBUG:-false}
      APP_URL: \${APP_URL:?APP_URL is required}
      APP_KEY: \${APP_KEY:?APP_KEY is required}
      LOG_CHANNEL: \${LOG_CHANNEL:-stack}
      LOG_LEVEL: \${LOG_LEVEL:-info}
      DB_CONNECTION: \${DB_CONNECTION:-pgsql}
      DB_HOST: \${DB_HOST:-db}
      DB_PORT: \${DB_PORT:-5432}
      DB_DATABASE: \${DB_DATABASE:?DB_DATABASE is required}
      DB_USERNAME: \${DB_USERNAME:?DB_USERNAME is required}
      DB_PASSWORD: \${DB_PASSWORD:?DB_PASSWORD is required}
      CACHE_STORE: \${CACHE_STORE:-database}
      QUEUE_CONNECTION: \${QUEUE_CONNECTION:-database}
      SESSION_DRIVER: \${SESSION_DRIVER:-database}
      RUN_MIGRATIONS: "false"
    depends_on:
      db:
        condition: service_healthy

  scheduler:
    build:
      context: .
      dockerfile: Dockerfile
    command: ["scheduler"]
    environment:
      APP_NAME: \${APP_NAME:-${PROJECT}}
      APP_ENV: \${APP_ENV:-production}
      APP_DEBUG: \${APP_DEBUG:-false}
      APP_URL: \${APP_URL:?APP_URL is required}
      APP_KEY: \${APP_KEY:?APP_KEY is required}
      LOG_CHANNEL: \${LOG_CHANNEL:-stack}
      LOG_LEVEL: \${LOG_LEVEL:-info}
      DB_CONNECTION: \${DB_CONNECTION:-pgsql}
      DB_HOST: \${DB_HOST:-db}
      DB_PORT: \${DB_PORT:-5432}
      DB_DATABASE: \${DB_DATABASE:?DB_DATABASE is required}
      DB_USERNAME: \${DB_USERNAME:?DB_USERNAME is required}
      DB_PASSWORD: \${DB_PASSWORD:?DB_PASSWORD is required}
      CACHE_STORE: \${CACHE_STORE:-database}
      QUEUE_CONNECTION: \${QUEUE_CONNECTION:-database}
      SESSION_DRIVER: \${SESSION_DRIVER:-database}
      RUN_MIGRATIONS: "false"
    depends_on:
      db:
        condition: service_healthy

  db:
    image: postgres:16-alpine
    environment:
      POSTGRES_DB: \${DB_DATABASE:?DB_DATABASE is required}
      POSTGRES_USER: \${DB_USERNAME:?DB_USERNAME is required}
      POSTGRES_PASSWORD: \${DB_PASSWORD:?DB_PASSWORD is required}
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U \${DB_USERNAME} -d \${DB_DATABASE}"]
      interval: 10s
      timeout: 5s
      retries: 10
    volumes:
      - postgres-data:/var/lib/postgresql/data

volumes:
  postgres-data:
EOF

write_file "${PROJECT_PATH}/.dockerignore" <<'EOF'
.git
.github
node_modules
vendor
storage/logs
storage/framework/cache
storage/framework/sessions
storage/framework/testing
storage/framework/views
.env
.env.*
EOF

write_file "${PROJECT_PATH}/.docker/app/entrypoint.sh" <<'EOF'
#!/bin/sh
set -eu

cd /var/www/html

mkdir -p \
  bootstrap/cache \
  storage/framework/cache \
  storage/framework/sessions \
  storage/framework/testing \
  storage/framework/views

chmod -R ug+rwX bootstrap/cache storage || true

php artisan storage:link || true

if [ "${RUN_MIGRATIONS:-true}" = "true" ]; then
  php artisan migrate --force || true
fi

mode="${1:-app}"
shift || true

case "$mode" in
  app)
    exec php artisan serve --host=0.0.0.0 --port=80
    ;;
  worker)
    exec php artisan queue:work --tries=1 --timeout=90
    ;;
  scheduler)
    exec sh -c 'while true; do php artisan schedule:run --no-interaction --verbose; sleep 60; done'
    ;;
  *)
    exec "$mode" "$@"
    ;;
esac
EOF

chmod +x "${PROJECT_PATH}/.docker/app/entrypoint.sh"

echo "==> Wrote deployment files in ${PROJECT_PATH}"
