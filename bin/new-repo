#!/usr/bin/env bash
set -euo pipefail

VERSION="dev"

usage() {
    cat <<'USAGE'
Usage: new-repo <repo-name> [--path <dir>] [--public|--private] [--description <text>] [--owner <owner>] [--remote <name>] [--dry-run] [--yes]

Options:
  --path <dir>           Project directory (default: ~/git/<repo-name>)
  --public               Create a public GitHub repo
  --private              Create a private GitHub repo (default)
  --description <text>   GitHub repository description
  --owner <owner>        GitHub owner/org (default: batjaa)
  --remote <name>        Git remote name (default: origin)
  --dry-run              Print validation and planned actions without changing anything
  --yes                  Skip confirmation prompt after validation
  --version              Print version
  -h, --help             Show this help
USAGE
}

if [[ $# -eq 0 ]]; then
    usage
    exit 1
fi

REPO_NAME=""
PROJECT_PATH=""
VISIBILITY="private"
DESCRIPTION=""
OWNER="batjaa"
REMOTE_NAME="origin"
DRY_RUN=false
ASSUME_YES=false

while [[ $# -gt 0 ]]; do
    case "$1" in
        --path) PROJECT_PATH="$2"; shift 2 ;;
        --public) VISIBILITY="public"; shift ;;
        --private) VISIBILITY="private"; shift ;;
        --description) DESCRIPTION="$2"; shift 2 ;;
        --owner) OWNER="$2"; shift 2 ;;
        --remote) REMOTE_NAME="$2"; shift 2 ;;
        --dry-run) DRY_RUN=true; shift ;;
        --yes) ASSUME_YES=true; shift ;;
        --version) echo "new-repo $VERSION"; exit 0 ;;
        -h|--help) usage; exit 0 ;;
        -*) echo "Unknown option: $1" >&2; exit 1 ;;
        *) REPO_NAME="$1"; shift ;;
    esac
done

if [[ -z "$REPO_NAME" ]]; then
    echo "Error: repo name required" >&2
    exit 1
fi

if [[ -z "$PROJECT_PATH" ]]; then
    PROJECT_PATH="${HOME}/git/${REPO_NAME}"
fi

if [[ ! -d "$PROJECT_PATH" ]]; then
    echo "Error: project directory '$PROJECT_PATH' does not exist" >&2
    exit 1
fi

if ! command -v gh >/dev/null 2>&1; then
    echo "Error: GitHub CLI 'gh' is required" >&2
    exit 1
fi

if ! gh auth status >/dev/null 2>&1; then
    echo "Error: GitHub CLI is not authenticated" >&2
    exit 1
fi

repo_exists=false
if gh repo view "${OWNER}/${REPO_NAME}" >/dev/null 2>&1; then
    repo_exists=true
fi

remote_exists=false
if [[ -d "${PROJECT_PATH}/.git" ]] && [[ -n "$(git -C "${PROJECT_PATH}" remote get-url "$REMOTE_NAME" 2>/dev/null || true)" ]]; then
    remote_exists=true
fi

echo "==> Validation"
echo "  project path: ${PROJECT_PATH}"
echo "  github repo: ${OWNER}/${REPO_NAME}"
echo "  local dir exists: yes"
echo "  repo available: $( $repo_exists && echo no || echo yes )"
echo "  remote '${REMOTE_NAME}' available: $( $remote_exists && echo no || echo yes )"
echo "  default branch target: main"

if $repo_exists; then
    echo "Error: GitHub repo '${OWNER}/${REPO_NAME}' already exists" >&2
    exit 1
fi

if $remote_exists; then
    echo "Error: git remote '${REMOTE_NAME}' already exists" >&2
    exit 1
fi

if $DRY_RUN; then
    echo "==> Dry run complete. No changes made."
    exit 0
fi

if ! $ASSUME_YES; then
    read -r -p "Proceed with GitHub repo creation and initial push? (y/N) " reply
    if [[ ! "$reply" =~ ^[Yy]$ ]]; then
        echo "Aborted."
        exit 1
    fi
fi

cd "$PROJECT_PATH"

if [[ ! -d .git ]]; then
    git init
fi

GH_ARGS=(repo create "${OWNER}/${REPO_NAME}" "--${VISIBILITY}")
if [[ -n "$DESCRIPTION" ]]; then
    GH_ARGS+=(--description "$DESCRIPTION")
fi

gh "${GH_ARGS[@]}"
git remote add "$REMOTE_NAME" "git@github.com:${OWNER}/${REPO_NAME}.git"

if ! git rev-parse --verify HEAD >/dev/null 2>&1; then
    git add .
    git commit -m "chore: initial commit"
fi

git branch -M main
current_branch="main"

git push -u "$REMOTE_NAME" "$current_branch"

echo "==> Created and pushed ${OWNER}/${REPO_NAME}"
